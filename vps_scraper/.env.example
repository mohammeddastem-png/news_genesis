# News Genesis VPS Scraper Configuration

# Firebase Configuration
FIREBASE_CREDS_PATH=./firebase-credentials.json
FIREBASE_DB_URL=https://your-project.firebaseio.com

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/news_genesis_scraper.log

# Scraping Configuration
SCRAPE_INTERVAL_HOURS=6
MAX_ARTICLES_PER_CHANNEL=50
TIMEOUT_SECONDS=10

# Al Jazeera URLs (Update if they change)
ALJAZEERA_ENGLISH_URL=https://www.aljazeera.com/news/
ALJAZEERA_ARABIC_URL=https://www.aljazeera.net/news/

# HLS Stream URLs
ALJAZEERA_ENGLISH_HLS=https://live-qatarstream.com/hls/alijazeera_enghd/index.m3u8
ALJAZEERA_ARABIC_HLS=https://live-qatarstream.com/hls/alijazeera_arabhd/index.m3u8

# Optional: Proxy Configuration (if behind proxy)
# PROXY_URL=http://proxy.example.com:8080
# PROXY_USERNAME=your_username
# PROXY_PASSWORD=your_password
